DISCORD_TOKEN=your_discord_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Dashboard (選填，不設定則 Dashboard 不啟動)
DASHBOARD_SECRET=random_secret_key_here
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
DASHBOARD_REDIRECT_URI=http://localhost:8080/auth/callback
DASHBOARD_ALLOWED_USERS=你的Discord用戶ID
DASHBOARD_PORT=8080

# GitHub 自動部署 (選填)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# ── WordPress 自動發文機器人 (wp_poster.py) ──────────────────
# WordPress.com OAuth2 設定
# 取得方式:
#   1. 到 https://developer.wordpress.com/apps/ 建立應用程式
#   2. 取得 Client ID 和 Client Secret
#   3. WP_USERNAME 填 WordPress.com 登入 email
#   4. WP_PASSWORD 填 Application Password（有 2FA 時）或帳號密碼
#   5. 或直接填 WP_ACCESS_TOKEN（可選，填了就不需要上面四項）
WP_SITE_URL=https://your-site.art.blog
WP_CLIENT_ID=your_client_id
WP_CLIENT_SECRET=your_client_secret
WP_USERNAME=your_email@example.com
WP_PASSWORD=your_app_password
WP_ACCESS_TOKEN=
WP_CATEGORY_ID=1
WP_DEFAULT_TAGS=PTT故事,連載小說,愛情故事

# PTT 爬蟲設定
PTT_BOARDS=Boy-Girl,marriage,sex
PTT_MIN_PUSH_COUNT=10

# 排程設定
MIN_QUEUE_SIZE=10
EPISODE_TARGET_CHARS=800

# ── Facebook 粉專自動同步 (選填) ──────────────────
# 取得方式:
#   1. 到 https://developers.facebook.com/ 建立應用程式
#   2. 新增「粉絲專頁」產品，取得 Page Access Token
#   3. 確保 token 有 pages_manage_posts 權限
#   4. FB_PAGE_ID 可在粉專「關於」頁面找到
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
